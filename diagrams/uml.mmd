classDiagram
    class Owner {
        -name: string
        -pets: List~Pet~
        +addPet(pet: Pet) void
        +getAllTasks() List~Task~
    }

    class Pet {
        -name: string
        -species: string
        -tasks: List~Task~
        +addTask(task: Task) void
        +getTasks() List~Task~
    }

    class Task {
        -description: string
        -time: string
        -frequency: string
        -completed: bool
        +markComplete() void
    }

    class Scheduler {
        -owner: Owner
        +getDailySchedule() List~Task~
        +sortByTime(tasks: List~Task~) List~Task~
    }

    Owner "1" --> "*" Pet : owns
    Pet "1" --> "*" Task : has
    Scheduler --> Owner : reads tasks from